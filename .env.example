# MySQL
MYSQL_ROOT_PASSWORD=lottery_root
MYSQL_DATABASE=lottery_ai
MYSQL_USER=lottery
MYSQL_PASSWORD=lottery_pass
MYSQL_PORT=3306

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend
BACKEND_PORT=8080
JWT_SECRET=change-me-to-a-long-random-secret-key-at-least-256-bits
JWT_EXPIRATION_MS=86400000

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=
VITE_AI_BASE_URL=http://localhost:8000

# AI Service
AI_SERVICE_PORT=8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Data Sync
SYNC_ENABLED=true
SYNC_CRON=0 */30 * * * *
SYNC_FEED_TYPE=mock
SYNC_FEED_URL=
SYNC_EXTERNAL_URL=
SYNC_EXTERNAL_API_KEY=
SYNC_EXTERNAL_API_KEY_HEADER=X-API-Key

# Kafka (Sprint 4)
KAFKA_ENABLED=true
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Sprint 5: Avro + Multi-Region + SLA
KAFKA_USE_AVRO=false
SCHEMA_REGISTRY_PORT=8081
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081
KAFKA_SCHEMA_VERSION=1.0
LOTTERY_REGION=local
SYNC_EXTERNAL_MAX_RETRIES=3
SYNC_EXTERNAL_TIMEOUT_MS=5000

# Sprint 6: SLA SLO
SLA_ALERT_ENABLED=true
SLA_MIN_SUCCESS_RATE=95
SLA_MAX_P95_MS=800

# Sprint 7: breach events + ops
KAFKA_TOPIC_SLA_BREACH=lottery.sla.breach
